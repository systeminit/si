eslint(
    name = "check-lint",
    directories = ["src", "tests"],
    srcs = [":src", ":test_src"] + glob([".eslint*"]),
    prod_deps_srcs = prod_deps_srcs,
    dev_deps_srcs = dev_deps_srcs,
)

typescript_check(
    name = "check-type",
    srcs = [":src"],
    prod_deps_srcs = prod_deps_srcs,
    dev_deps_srcs = dev_deps_srcs,
)

ts_test(
    name = "test-unit",
    srcs = [":src", ":test_src"],
    prod_deps_srcs = prod_deps_srcs,
    dev_deps_srcs = dev_deps_srcs,
)

nix_omnibus_pkg(
    name = "omnibus",
    pkg_name = "lang-js",
    build_dep = "//bin/lang-js:bin",
)

pnpm_task_binary(
    name = "docs",
    command = "docs",
    srcs = glob(["src/**/*"]),
    path = "bin/lang-js",
    deps = [
        "//:node_modules",
    ],
    visibility = ["PUBLIC"],
)
