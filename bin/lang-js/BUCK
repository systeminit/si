load(
    "@prelude-si//:macros.bzl",
    "eslint",
    "export_file",
    "ts_test",
    "nix_omnibus_pkg",
    "node_pkg_bin",
    "npm_bin",
    "package_node_modules",
    "prettier_check",
    "typescript_check",
    "typescript_dist",
    "typescript_runnable_dist",
    "typescript_runnable_dist_bin",
)
load(
    "@prelude-si//:pnpm.bzl",
    "pnpm_task_library",
    "pnpm_task_binary",
    "pnpm_task_test",
)
load(
    "@prelude-si//:deno.bzl",
    "deno_binary",
    "deno_format",
)

export_file(
    name = "package.json",
)

package_node_modules(
    name = "node_modules",
)

filegroup(
    name = "src",
    srcs = glob([
        "src/**/*.ts",
        "tsconfig.json",
    ]),
)

filegroup(
    name = "test_src",
    srcs = glob([
        "tests/**/*",
    ]),
)

prod_deps_srcs = {
    "lib/ts-lib": "//lib/ts-lib:src",
}

deno_binary(
    name = "lang-js",
    main = "src/index.ts",
    out = "lang-js",
    permissions = [
        "allow-all",
    ],
    unstable_flags = [
        "worker-options",
    ],
    visibility = ["PUBLIC"],
)

deno_format(
    name = "fix-format",
    srcs = glob(["**/*.ts", "**/*.js"]),
    ignore = ["node_modules"],
)

deno_format(
    name = "check-format",
    srcs = glob(["**/*.ts", "**/*.js"]),
    check = True,
)

dev_deps_srcs = {
    "lib/eslint-config": "//lib/eslint-config:src",
    "lib/tsconfig": "//lib/tsconfig:src",
}

npm_bin(
    name = "tsup",
)

typescript_dist(
    name = "dist",
    srcs = [":src"],
    tsup = ":tsup",
    prod_deps_srcs = prod_deps_srcs,
    dev_deps_srcs = dev_deps_srcs,
)

